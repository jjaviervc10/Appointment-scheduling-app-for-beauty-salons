{
  "expo": {
    "name": "Jaquelina López Barber Studio",
    "slug": "jaquelina-lopez-barber-studio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "jlbarber",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jlbarber.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A1A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jlbarber.app"
    },
    "web": {
      "favicon": "./assets/LogoJL.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
