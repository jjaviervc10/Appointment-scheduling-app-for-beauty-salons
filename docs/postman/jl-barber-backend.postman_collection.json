              "raw": "{\n  \"fullName\": \"Test\",\n  \"phone\": \"+526141234567\",\n  \"serviceId\": \"00000000-0000-0000-0000-000000000001\",\n  \"startAt\": \"2026-05-10T16:07:00.000Z\"\n}"
            },
